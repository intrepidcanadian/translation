{
  "expo": {
    "name": "Live Translator",
    "slug": "mobiletranslator",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "This app uses speech recognition to provide live translation.",
        "NSMicrophoneUsageDescription": "This app needs microphone access to listen and translate speech in real time."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Live Translator to access your microphone for real-time speech translation.",
          "speechRecognitionPermission": "Allow Live Translator to use speech recognition for live translation."
        }
      ],
      "expo-quick-actions",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "TranslateWidget",
              "label": "Live Translator",
              "description": "Quick translate widget with voice and paste shortcuts",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "widgetFeatures": "reconfigurable"
            }
          ]
        }
      ]
    ]
  }
}
