{
  "name": "mobiletranslator",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "NODE_OPTIONS='--localstorage-file=/tmp/jest-ls' jest --runInBand",
    "test:ci": "NODE_OPTIONS='--localstorage-file=/tmp/jest-ls' jest --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "preset": "jest-expo/ios",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.claude/",
      "/src/types/__type_tests__/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg)"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-community/slider": "5.0.1",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@react-native-ml-kit/translate-text": "^0.5.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-print": "~15.0.8",
    "expo-quick-actions": "^6.0.1",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-speech-recognition": "^3.1.2",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-android-widget": "^0.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-vision-camera": "^4.7.3",
    "react-native-vision-camera-ocr-plus": "^1.2.4",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.3",
    "transliteration": "^2.6.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.16",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@react-native-ml-kit/text-recognition",
          "@react-native-ml-kit/translate-text",
          "react-native-vision-camera-ocr-plus",
          "apple-translation"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
